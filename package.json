{
  "name": "sweet-fork-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --no-warnings --experimental-strip-types --test src/lib/pricing.test.ts src/lib/site/product-media.test.ts src/lib/admin/media-placement-utils.test.ts src/lib/admin/order-status.test.ts src/components/admin/more-menu-sheet-classes.test.ts src/components/admin/admin-shell-chrome.test.ts src/components/admin/media-library-manager.test.ts src/lib/inquiries/submit.test.ts src/components/inquiry/wizard-helpers.test.ts",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" next.config.ts tailwind.config.ts --cache --cache-location .eslintcache --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit --project tsconfig.typecheck.json",
    "db:push": "supabase db push",
    "db:typegen": "supabase gen types typescript --linked --schema public > src/types/supabase.generated.ts",
    "db:verify:seed": "node --env-file=.env.local scripts/verify-reference-data.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.10",
    "supabase": "^2.84.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
