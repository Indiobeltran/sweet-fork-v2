{
  "name": "sweet-fork-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src middleware.ts next.config.ts tailwind.config.ts --ext .js,.jsx,.ts,.tsx --cache --cache-location .eslintcache --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit --project tsconfig.typecheck.json",
    "db:push": "supabase db push",
    "db:typegen": "supabase gen types typescript --linked --schema public > src/types/supabase.generated.ts",
    "db:verify:seed": "node --env-file=.env.local scripts/verify-reference-data.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.1",
    "postcss": "^8.5.3",
    "supabase": "^2.84.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
